---
import "@fontsource-variable/inter";
import "@fontsource/playfair-display/400.css";
import "@fontsource/playfair-display/400-italic.css";
import "@fontsource/playfair-display/700.css";
import "@fontsource/playfair-display/700-italic.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/500.css";

import "../styles/global.css";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Campbell K9's — Quietly Serious Dog Training | Boston & Providence",
  description = "Coastal New England dog training, off-leash adventure hikes, and luxury boarding. By appointment, for a small number of dogs year-round.",
  ogImage = "/ck9-blue-logo@2x.webp",
} = Astro.props;

const siteUrl = "https://campbellk9s.com";
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const absoluteOgImage = new URL(ogImage, Astro.site).toString();
const cleanTitle = title
  .replace(/&#(\d+);/g, (_, code) => String.fromCodePoint(Number(code)))
  .replace(/&#x([\da-f]+);/gi, (_, code) => String.fromCodePoint(parseInt(code, 16)))
  .replace(/&amp;/g, "&")
  .replace(/&quot;/g, '"')
  .replace(/&#0?39;|&apos;/g, "'")
  .replace(/&lt;/g, "<")
  .replace(/&gt;/g, ">");
const breadcrumbParts = Astro.url.pathname.split("/").filter(Boolean);
const breadcrumbItems = [
  { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
  ...breadcrumbParts.map((part, index) => ({
    "@type": "ListItem",
    position: index + 2,
    name:
      index === breadcrumbParts.length - 1
        ? cleanTitle.replace(" | Campbell K9's", "").replace(" — Campbell K9's", "")
        : part.replace(/-/g, " ").replace(/\b\w/g, (letter) => letter.toUpperCase()),
    item: `${siteUrl}/${breadcrumbParts.slice(0, index + 1).join("/")}/`,
  })),
];
const graph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      url: `${siteUrl}/`,
      name: "Campbell K9's",
      publisher: { "@id": `${siteUrl}/#business` },
      inLanguage: "en-US",
    },
    {
      "@type": "LocalBusiness",
      "@id": `${siteUrl}/#business`,
      name: "Campbell K9's",
      description,
      url: `${siteUrl}/`,
      email: "k9campbellmatt@gmail.com",
      image: absoluteOgImage,
      priceRange: "$$$$",
      areaServed: [
        { "@type": "City", name: "Boston", containedInPlace: "Massachusetts" },
        {
          "@type": "City",
          name: "Providence",
          containedInPlace: "Rhode Island",
        },
        { "@type": "City", name: "Newport", containedInPlace: "Rhode Island" },
      ],
      serviceType: [
        "Dog Training",
        "Board and Train",
        "Off-Leash Adventure Hikes",
        "Premium Overnight Boarding",
      ],
      knowsAbout: [
        "Behavioral Training",
        "Off-Leash Reliability",
        "Reactivity Rehabilitation",
        "Pack Walks",
      ],
    },
    {
      "@type": "WebPage",
      "@id": canonical,
      url: canonical,
      name: cleanTitle,
      isPartOf: { "@id": `${siteUrl}/#website` },
      breadcrumb: { "@id": `${canonical}#breadcrumb` },
      description,
      inLanguage: "en-US",
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${canonical}#breadcrumb`,
      itemListElement: breadcrumbItems,
    },
  ],
};
const serializedGraph = JSON.stringify(graph).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0F1C2E" />

    <link rel="preconnect" href="https://cdn.curator.io" crossorigin />
    <link rel="preconnect" href="https://connect.facebook.net" crossorigin />
    <link rel="preconnect" href="https://i.ytimg.com" crossorigin />
    <link rel="preconnect" href="https://yt3.ggpht.com" crossorigin />

    <title>{cleanTitle}</title>
    <link rel="canonical" href={canonical} />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta property="og:title" content={cleanTitle} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:alt" content={`Campbell K9's — ${cleanTitle}`} />
    <meta property="og:url" content={canonical} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Campbell K9's" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/png" href="/ck9-icon-red-blue.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <script type="application/ld+json" set:html={serializedGraph}></script>
  </head>
  <body class="flex min-h-screen flex-col bg-brand-bg text-brand-primary">
    <Navigation />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
