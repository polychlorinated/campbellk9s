---
import "@fontsource-variable/inter";
import "@fontsource/playfair-display/400.css";
import "@fontsource/playfair-display/400-italic.css";
import "@fontsource/playfair-display/700.css";
import "@fontsource/playfair-display/700-italic.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/500.css";

import "../styles/global.css";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import Seo from "@jdevalk/astro-seo-graph/Seo.astro";
import { breadcrumbsFromUrl } from "@jdevalk/astro-seo-graph";
import {
  makeIds,
  assembleGraph,
  buildWebSite,
  buildWebPage,
  buildBreadcrumbList,
} from "@jdevalk/seo-graph-core";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Campbell K9 — Quietly Serious Dog Training | Boston & Providence",
  description = "Coastal New England dog training, off-leash adventure hikes, and luxury boarding. By appointment, for a small number of dogs each season.",
  ogImage = "/ck9-blue-logo@2x.webp",
} = Astro.props;

const siteUrl = "https://campbellk9s.com";
const ids = makeIds({ siteUrl });
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const absoluteOgImage = new URL(ogImage, Astro.site).toString();

const breadcrumbItems = breadcrumbsFromUrl({
  url: Astro.url,
  siteUrl,
  pageName: title.replace(" | Campbell K9", "").replace(" — Campbell K9", ""),
});

const graph = assembleGraph([
  buildWebSite(
    {
      url: `${siteUrl}/`,
      name: "Campbell K9",
      publisher: { "@id": `${siteUrl}/#business` },
      inLanguage: "en-US",
    },
    ids,
  ),
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": `${siteUrl}/#business`,
    name: "Campbell K9",
    description,
    url: `${siteUrl}/`,
    email: "k9campbellmatt@gmail.com",
    image: absoluteOgImage,
    priceRange: "$$$$",
    areaServed: [
      { "@type": "City", name: "Boston", containedInPlace: "Massachusetts" },
      {
        "@type": "City",
        name: "Providence",
        containedInPlace: "Rhode Island",
      },
      { "@type": "City", name: "Newport", containedInPlace: "Rhode Island" },
    ],
    serviceType: [
      "Dog Training",
      "Board and Train",
      "Off-Leash Adventure Hikes",
      "Premium Overnight Boarding",
    ],
    knowsAbout: [
      "Behavioral Training",
      "Off-Leash Reliability",
      "Reactivity Rehabilitation",
      "Pack Walks",
    ],
  },
  buildWebPage(
    {
      url: canonical,
      name: title,
      isPartOf: { "@id": ids.website },
      breadcrumb: { "@id": ids.breadcrumb(canonical) },
      description,
    },
    ids,
  ),
  buildBreadcrumbList(
    {
      url: canonical,
      items: breadcrumbItems,
    },
    ids,
  ),
]);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0F1C2E" />

    <link rel="preconnect" href="https://cdn.curator.io" crossorigin />
    <link rel="preconnect" href="https://connect.facebook.net" crossorigin />
    <link rel="preconnect" href="https://i.ytimg.com" crossorigin />
    <link rel="preconnect" href="https://yt3.ggpht.com" crossorigin />

    <Seo
      title={title}
      description={description}
      canonical={canonical}
      ogType="website"
      ogImage={absoluteOgImage}
      ogImageAlt={`Campbell K9 — ${title}`}
      siteName="Campbell K9"
      twitter={{ card: "summary_large_image" }}
      graph={graph}
      extraLinks={[
        { rel: "icon", type: "image/svg+xml", href: "/favicon.svg" },
        { rel: "sitemap", href: "/sitemap-index.xml" },
      ]}
    />
  </head>
  <body class="flex min-h-screen flex-col bg-brand-bg text-brand-primary">
    <Navigation />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
