---
const n8nWebhookUrl =
  import.meta.env.N8N_WEBHOOK_URL ??
  "https://n8n.srv725961.hstgr.cloud/webhook/ec01ad68-6e29-4130-b016-76452eded072";

const goalOptions = [
  { value: "puppy-training", label: "Puppy Training Program" },
  { value: "basic-obedience", label: "Basic Obedience Training" },
  { value: "bootcamp", label: "Board & Train Program" },
  { value: "hikes", label: "Adventure Hikes" },
  { value: "leash-walks", label: "Leash Walks" },
  { value: "pet-sitting", label: "In-Home Pet Sitting" },
  { value: "behavior", label: "Behavior Modification" },
  { value: "scholarship", label: "Scholarship Program" },
  { value: "other", label: "Something else" },
];
---

<section
  id="contact"
  class="relative bg-brand-bg"
  aria-labelledby="contact-heading"
>
  <div class="hairline mx-auto max-w-7xl"></div>
  <div class="mx-auto max-w-7xl px-6 py-28 sm:px-10 sm:py-36 lg:px-16 lg:py-44">
    <div class="grid gap-y-14 lg:grid-cols-12 lg:gap-x-16">
      <div class="lg:col-span-5">
        <p class="caption text-brand-accent">Begin a Conversation</p>
        <h2
          id="contact-heading"
          class="mt-6 text-balance font-serif text-4xl leading-[1.05] sm:text-5xl lg:text-6xl"
        >
          Quietly serious work,<br />
          <span class="italic text-brand-accent">by reservation.</span>
        </h2>
        <p
          class="mt-8 max-w-md text-lg leading-relaxed text-brand-primary/75 sm:text-xl"
        >
          We take a small number of new dogs by appointment, year-round. Tell us about yours —
          the good, the challenging, and the funny — and our lead trainer will
          write back within twenty-four hours.
        </p>

        <div class="mt-12 hairline max-w-[3rem]"></div>

        <dl
          class="mt-10 grid grid-cols-1 gap-y-8 sm:grid-cols-2 sm:gap-x-10"
        >
          <div>
            <dt class="caption text-brand-primary/55">By Appointment</dt>
            <dd class="mt-2 font-serif text-lg text-brand-primary">
              Greater Boston
            </dd>
            <dd class="mt-1 font-serif text-lg text-brand-primary">
              Providence, RI
            </dd>
          </div>
          <div>
            <dt class="caption text-brand-primary/55">Direct</dt>
            <dd class="mt-2 text-base text-brand-primary">
              <a
                href="mailto:k9campbellmatt@gmail.com"
                class="border-b border-brand-primary/30 pb-0.5 transition-colors hover:border-brand-accent hover:text-brand-accent"
              >
                k9campbellmatt@gmail.com
              </a>
            </dd>
            <dd class="mt-2 text-base text-brand-primary">
              <a
                href="tel:+14014809471"
                class="border-b border-brand-primary/30 pb-0.5 transition-colors hover:border-brand-accent hover:text-brand-accent"
              >
                (401) 480-9471
              </a>
            </dd>
          </div>
        </dl>
      </div>

      <div class="lg:col-span-7">
        <form
          class="space-y-10"
          data-contact-form
          data-webhook-url={n8nWebhookUrl}
          novalidate
          aria-describedby="contact-form-status"
        >
          <div class="field">
            <label for="contact-name" class="caption text-brand-primary/55">
              Name
            </label>
            <input
              id="contact-name"
              name="name"
              type="text"
              autocomplete="name"
              required
              class="mt-3 block w-full border-0 border-b border-brand-primary/25 bg-transparent pb-3 font-serif text-lg text-brand-primary placeholder:font-serif placeholder:italic placeholder:text-brand-primary/35 focus:border-brand-accent focus:outline-none focus:ring-0"
              placeholder="Your full name"
            />
          </div>

          <div class="field">
            <label
              for="contact-phone"
              class="caption text-brand-primary/55"
            >
              Phone
            </label>
            <input
              id="contact-phone"
              name="phone"
              type="tel"
              autocomplete="tel"
              required
              class="mt-3 block w-full border-0 border-b border-brand-primary/25 bg-transparent pb-3 font-serif text-lg text-brand-primary placeholder:font-serif placeholder:italic placeholder:text-brand-primary/35 focus:border-brand-accent focus:outline-none focus:ring-0"
              placeholder="(401) 555-0100"
            />
          </div>

          <div class="field">
            <label for="contact-dog" class="caption text-brand-primary/55">
              Dog &mdash; Breed &amp; Age
            </label>
            <input
              id="contact-dog"
              name="dog"
              type="text"
              required
              class="mt-3 block w-full border-0 border-b border-brand-primary/25 bg-transparent pb-3 font-serif text-lg text-brand-primary placeholder:font-serif placeholder:italic placeholder:text-brand-primary/35 focus:border-brand-accent focus:outline-none focus:ring-0"
              placeholder="e.g. two-year-old Vizsla"
            />
          </div>

          <div class="field relative">
            <label for="contact-goal" class="caption text-brand-primary/55">
              Primary Goal
            </label>
            <select
              id="contact-goal"
              name="goal"
              required
              class="peer mt-3 block w-full appearance-none border-0 border-b border-brand-primary/25 bg-transparent pb-3 pr-10 font-serif text-lg text-brand-primary focus:border-brand-accent focus:outline-none focus:ring-0"
            >
              <option value="" disabled selected>Select an intention…</option>
              {
                goalOptions.map((g) => (
                  <option value={g.value}>{g.label}</option>
                ))
              }
            </select>
            <span
              class="pointer-events-none absolute right-1 bottom-3 text-brand-primary/40 transition-colors peer-focus:text-brand-accent"
              aria-hidden="true"
            >
              <svg
                class="h-4 w-4"
                viewBox="0 0 16 16"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path
                  d="M3 6l5 5 5-5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </span>
          </div>

          <div class="pt-4">
            <button
              type="submit"
              class="group relative inline-flex items-center gap-3 bg-brand-primary px-8 py-4 text-sm font-medium uppercase tracking-[0.18em] text-brand-bg transition-all duration-300 hover:bg-brand-accent disabled:cursor-not-allowed disabled:opacity-60"
            >
              <span data-submit-label>Send Inquiry</span>
              <span
                class="inline-block transition-transform duration-300 group-hover:translate-x-1"
                aria-hidden="true"
              >
                &rarr;
              </span>
            </button>
            <p
              id="contact-form-status"
              data-form-message
              role="status"
              aria-live="polite"
              class="mt-6 hidden font-serif text-base italic"
            >
            </p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
  const submitBtn = form?.querySelector<HTMLButtonElement>(
    'button[type="submit"]'
  );
  const submitLabel = form?.querySelector<HTMLSpanElement>(
    "[data-submit-label]"
  );
  const message = form?.querySelector<HTMLParagraphElement>(
    "[data-form-message]"
  );

  function showMessage(text: string, tone: "success" | "error") {
    if (!message) return;
    message.textContent = text;
    message.classList.remove("hidden", "text-brand-accent", "text-red-700");
    message.classList.add(
      tone === "success" ? "text-brand-accent" : "text-red-700"
    );
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!form || !submitBtn || !submitLabel) return;

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const data = Object.fromEntries(new FormData(form).entries());

    submitBtn.disabled = true;
    submitLabel.textContent = "Sending…";

    const webhookUrl = form.dataset.webhookUrl;
    if (!webhookUrl) {
      showMessage(
        "The form is not configured. Please write to k9campbellmatt@gmail.com.",
        "error"
      );
      return;
    }

    try {
      const res = await fetch(webhookUrl, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        form.reset();
        showMessage(
          "Thank you. Our lead trainer will write back within twenty-four hours.",
          "success"
        );
      } else {
        const text = await res.text().catch(() => "");
        console.error("[contact] n8n error", res.status, text);
        showMessage(
          "Something went wrong. Please try again, or write to k9campbellmatt@gmail.com.",
          "error"
        );
      }
    } catch (err) {
      console.error("[contact] network error", err);
      showMessage(
        "We couldn't reach our intake system. Please try again, or write to k9campbellmatt@gmail.com.",
        "error"
      );
    } finally {
      submitBtn.disabled = false;
      submitLabel.textContent = "Send Inquiry";
    }
  });
</script>
