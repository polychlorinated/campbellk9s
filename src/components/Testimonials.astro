---
const testimonials = [
  {
    quote:
      "We did board training for our dog Daisy who was anxious around other dogs and in public settings as a result of abuse prior to us adopting her. With just one week of training, the difference was clear. She is confident, friendly, and takes off-leash hikes happily with the pack each week.",
    name: "Becca Rutenberg",
    location: "Google Review",
    dog: "Daisy",
  },
  {
    quote:
      "Matt and Mary were so helpful in getting our 1-year old Labradoodle Tate into Training Bootcamp. Matt gave us helpful insight, guidance and training tools to make our lives together with Tate run smoother and happier for all — Thank you!!!",
    name: "Mary Ellen Paravalos",
    location: "Google Review",
    dog: "Tate, Labradoodle",
  },
  {
    quote:
      "Our main focus was off-leash training, recall, jumping on guests and counter surfing. All behaviors were corrected. Benson has been part of the adventure hikes for 2 years now and absolutely loves it. It gives me peace of mind knowing he is in good hands and they treat him like their own family dog!",
    name: "Ashley Shaw",
    location: "Google Review",
    dog: "Benson, Sheepadoodle",
  },
];
---

<section
  id="testimonials"
  class="relative bg-brand-bg"
  aria-labelledby="testimonials-heading"
>
  <div class="hairline mx-auto max-w-7xl"></div>
  <div class="mx-auto max-w-7xl px-6 py-28 sm:px-10 sm:py-36 lg:px-16 lg:py-44">
    <div class="grid gap-y-10 lg:grid-cols-12 lg:gap-x-12">
      <div class="lg:col-span-4">
        <p class="caption text-brand-accent">From Our Clients</p>
        <div class="mt-6 hairline max-w-[3rem]"></div>
      </div>
      <div class="lg:col-span-8">
        <h2
          id="testimonials-heading"
          class="max-w-3xl text-balance font-serif text-4xl leading-[1.05] sm:text-5xl lg:text-6xl"
        >
          The families
          <em class="not-italic font-serif italic text-brand-accent">
            who trusted the work.
          </em>
        </h2>
      </div>
    </div>

    <div class="mt-20 grid gap-x-12 gap-y-16 lg:grid-cols-3">
      {
        testimonials.map((t) => (
          <figure class="flex flex-col">
            <span
              class="font-serif text-5xl leading-none text-brand-accent"
              aria-hidden="true"
            >
              &ldquo;
            </span>
            <blockquote class="mt-4 flex-1 font-serif text-lg italic leading-relaxed text-brand-primary sm:text-xl">
              {t.quote}
            </blockquote>
            <figcaption class="mt-8 border-t border-brand-line pt-6">
              <p class="font-serif text-base text-brand-primary">{t.name}</p>
              <p class="caption mt-1 text-brand-primary/55">
                {t.location} &middot; {t.dog}
              </p>
            </figcaption>
          </figure>
        ))
      }
    </div>

    <div class="mt-16 hairline max-w-7xl"></div>
    <div class="mt-10 flex items-center justify-between gap-6">
      <p class="caption text-brand-primary/45">Read more reviews on Google.</p>
      <a
        href="/reviews/"
        class="group inline-flex items-center gap-3 text-sm font-medium uppercase tracking-[0.18em] text-brand-primary/70 transition-colors hover:text-brand-primary"
      >
        <span class="h-px w-8 bg-current transition-all group-hover:w-12"></span>
        See all reviews
      </a>
    </div>
  </div>
</section>
