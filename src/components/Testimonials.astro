---
const testimonials = [
  {
    quote:
      "We came with a two-year-old German Shepherd who wouldn't walk past another dog without lunging. Four weeks later, he heeled through the North End on a Saturday morning. The work is real.",
    name: "Sarah M.",
    location: "Beacon Hill, MA",
    dog: "German Shepherd, 2 yrs",
  },
  {
    quote:
      "What I didn't expect was how much calmer our household became. It wasn't just the dog who changed.",
    name: "James T.",
    location: "Providence, RI",
    dog: "Labrador, 18 mos",
  },
  {
    quote:
      "My Vizsla completed the bootcamp and has never once failed to come when called — off-leash, at the beach, with other dogs running past.",
    name: "Claire D.",
    location: "Newport, RI",
    dog: "Vizsla, 3 yrs",
  },
];
---

<section
  id="testimonials"
  class="relative bg-brand-bg"
  aria-labelledby="testimonials-heading"
>
  <div class="hairline mx-auto max-w-7xl"></div>
  <div class="mx-auto max-w-7xl px-6 py-28 sm:px-10 sm:py-36 lg:px-16 lg:py-44">
    <div class="grid gap-y-10 lg:grid-cols-12 lg:gap-x-12">
      <div class="lg:col-span-4">
        <p class="caption text-brand-accent">From Our Clients</p>
        <div class="mt-6 hairline max-w-[3rem]"></div>
      </div>
      <div class="lg:col-span-8">
        <h2
          id="testimonials-heading"
          class="max-w-3xl text-balance font-serif text-4xl leading-[1.05] sm:text-5xl lg:text-6xl"
        >
          The families
          <em class="not-italic font-serif italic text-brand-accent">
            who trusted the work.
          </em>
        </h2>
      </div>
    </div>

    <div class="mt-20 grid gap-x-12 gap-y-16 lg:grid-cols-3">
      {
        testimonials.map((t) => (
          <figure class="flex flex-col">
            <span
              class="font-serif text-5xl leading-none text-brand-accent"
              aria-hidden="true"
            >
              &ldquo;
            </span>
            <blockquote class="mt-4 flex-1 font-serif text-lg italic leading-relaxed text-brand-primary sm:text-xl">
              {t.quote}
            </blockquote>
            <figcaption class="mt-8 border-t border-brand-line pt-6">
              <p class="font-serif text-base text-brand-primary">{t.name}</p>
              <p class="caption mt-1 text-brand-primary/55">
                {t.location} &middot; {t.dog}
              </p>
            </figcaption>
          </figure>
        ))
      }
    </div>

    <div class="mt-16 hairline max-w-7xl"></div>
    <div class="mt-10 flex items-center justify-between gap-6">
      <p class="caption text-brand-primary/45">Including Abby's Board & Train story on film.</p>
      <a
        href="/testimonials"
        class="group inline-flex items-center gap-3 text-sm font-medium uppercase tracking-[0.18em] text-brand-primary/70 transition-colors hover:text-brand-primary"
      >
        <span class="h-px w-8 bg-current transition-all group-hover:w-12"></span>
        See all stories
      </a>
    </div>
  </div>
</section>
