---
import ShotList from "./ShotList.astro";

const stages = [
  {
    number: "01",
    name: "Foundation",
    program: "Board & Train Bootcamp",
    duration: "Two to four weeks · In residence",
    body:
      "We bring the dog into our home for two to four weeks. The work is not theatrical — it is daily, consistent, and built on what the dog already wants. You receive a different animal back, and the language to keep them that way.",
    shot:
      "Quiet morning interior. Wool blanket on a wide-plank floor. A young dog in a sit-stay near a leather leash hanging on a hook. Soft window light, warm tones.",
    aspect: "4 / 5",
    image: "/stage1-foundation-dog-resting.webp",
  },
  {
    number: "02",
    name: "Discovery",
    program: "Adventure Hikes & Pack Walks",
    duration: "Standing weekly · Curated pack",
    body:
      "Once foundational, the dog needs the world. Our pack walks move through woodland trails, open fields, and quiet conservation land. Off-leash where appropriate. Always supervised. Always with intent.",
    shot:
      "Wide aspect, overcast diffuse light. A small balanced pack of dogs moving through a New England forest trail in autumn. Trainer walking ahead, calm, off-leash.",
    aspect: "16 / 10",
  },
  {
    number: "03",
    name: "Sanctuary",
    program: "Premium Overnight Boarding",
    duration: "By reservation · Program clients",
    body:
      "When you travel, your dog comes back to a place they already trust — the same trainers, the same routine, the same standard. Reserved for clients of the program. Always limited.",
    shot:
      "Late evening interior. A dog asleep on a wool-blanketed bed in a softly lit room. A reading lamp, an open book on a side table. Warm, hushed.",
    aspect: "4 / 5",
  };
---

<section
  id="journey"
  class="relative bg-brand-primary text-brand-bg"
  aria-labelledby="journey-heading"
>
  <div class="mx-auto max-w-7xl px-6 py-28 sm:px-10 sm:py-36 lg:px-16 lg:py-44">
    <div class="grid gap-y-10 lg:grid-cols-12 lg:gap-x-12">
      <div class="lg:col-span-5">
        <p class="caption text-brand-accent">The Journey</p>
        <h2
          id="journey-heading"
          class="mt-6 text-balance font-serif text-4xl leading-[1.05] text-brand-bg sm:text-5xl lg:text-6xl"
        >
          Three stages of a <em
            class="not-italic font-serif italic text-brand-accent"
          >
            single relationship.
          </em>
        </h2>
      </div>
      <div class="lg:col-span-6 lg:col-start-7 lg:pt-6">
        <p class="text-lg leading-relaxed text-brand-bg/75 sm:text-xl">
          Our work is a continuum, not a catalogue. Each stage opens the
          next; each is reserved for a small number of families a year.
        </p>
      </div>
    </div>

    <div class="mt-20 space-y-24 sm:space-y-32">
      {
        stages.map((stage, i) => {
          const imageFirst = i % 2 === 0;
          return (
            <div class="grid items-center gap-y-10 lg:grid-cols-12 lg:gap-x-16">
              <div
                class:list={[
                  "lg:col-span-7",
                  imageFirst ? "lg:order-1" : "lg:order-2",
                ]}
              >
                {stage.image ? (
                  <img
                    src={stage.image}
                    alt={stage.shot}
                    class="w-full border border-brand-bg/15 object-cover"
                    style={`aspect-ratio: ${stage.aspect};`}
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <ShotList
                    shot={stage.shot}
                    aspect={stage.aspect}
                    tone="ink"
                  />
                )}
              </div>

              <div
                class:list={[
                  "lg:col-span-5",
                  imageFirst ? "lg:order-2" : "lg:order-1",
                ]}
              >
                <p
                  aria-hidden="true"
                  class="font-serif text-7xl font-bold leading-none text-brand-accent sm:text-8xl"
                >
                  {stage.number}
                </p>
                <p class="caption mt-6 text-brand-bg/55">
                  Stage {stage.number} &middot; {stage.name}
                </p>
                <h3 class="mt-3 font-serif text-3xl leading-tight text-brand-bg sm:text-4xl">
                  {stage.program}
                </h3>
                <div class="mt-6 hairline max-w-[3rem] bg-brand-bg/30" />
                <p class="mt-6 text-base leading-relaxed text-brand-bg/80 sm:text-lg">
                  {stage.body}
                </p>
                <p class="caption mt-8 text-brand-bg/45">
                  {stage.duration}
                </p>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
