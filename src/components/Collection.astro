---
import ShotList from "./ShotList.astro";

const places = [
  {
    location: "Newport, RI",
    title: "The Cliff Walk",
    body:
      "Three and a half miles of Atlantic, with your dog walking the line where land becomes sea. Best in October light, before the season turns.",
    season: "Autumn · Cool light",
    shot:
      "Shallow depth of field, warm tones. A composed dog mid-stride along the Newport Cliff Walk at golden hour, ocean blurred behind. Soft natural light.",
    aspect: "4 / 5",
  },
  {
    location: "Beacon Hill, MA",
    title: "Cobblestones at Dusk",
    body:
      "Quiet streets, lantern light, a dog who heels because the world feels safe. Practical training in one of the country's most particular neighborhoods.",
    season: "Winter · Lantern hour",
    shot:
      "Gas-lamp light on wet brick. A dog heeling beside a wool-coated owner on a Beacon Hill cobblestone street. Restrained, cinematic.",
    aspect: "5 / 4",
  },
  {
    location: "Boston, MA",
    title: "The North End Café",
    body:
      "An espresso outdoors. A dog at your feet, unbothered by passing strollers. The mark of a finished animal — visible only when nothing happens.",
    season: "Spring · Soft morning",
    shot:
      "Shallow depth of field, warm tones. Dog behaving beautifully at an outdoor Boston North End café. Espresso cup, linen napkin, owner reading.",
    aspect: "5 / 4",
  },
  {
    location: "South Boston, MA",
    title: "Castle Island, Open Water",
    body:
      "Off-leash recall against the working harbor. The point is not the swim. The point is the return.",
    season: "Summer · Working light",
    shot:
      "Wide aspect, overcast diffuse light. Working harbor in soft focus behind. A dog mid-recall on the grass at Castle Island, drawn back toward an owner just out of frame.",
    aspect: "21 / 9",
  },
];
---

<section
  id="collection"
  class="relative bg-brand-bg"
  aria-labelledby="collection-heading"
>
  <div class="hairline mx-auto max-w-7xl"></div>
  <div class="mx-auto max-w-7xl px-6 py-28 sm:px-10 sm:py-36 lg:px-16 lg:py-44">
    <div
      class="grid gap-y-10 lg:grid-cols-12 lg:gap-x-12 xl:gap-x-20"
    >
      <div class="lg:col-span-4">
        <p class="caption text-brand-accent">The Collection</p>
        <h2
          id="collection-heading"
          class="mt-6 text-balance font-serif text-4xl leading-[1.05] sm:text-5xl lg:text-6xl"
        >
          A finer life,<br />
          <span class="italic text-brand-accent">already nearby.</span>
        </h2>
      </div>
      <div class="lg:col-span-7 lg:col-start-6">
        <p class="text-lg leading-relaxed text-brand-primary/75 sm:text-xl">
          Four standing settings where the work of a season becomes
          visible &mdash; one mile of coast, one cobblestone, one café, one
          quiet return.
        </p>
      </div>
    </div>

    <div
      class="mt-20 grid grid-cols-12 gap-x-6 gap-y-16 sm:gap-x-8 sm:gap-y-20"
    >
      <article
        class="col-span-12 lg:col-span-7 lg:row-span-2 flex flex-col"
      >
        <ShotList shot={places[0].shot} aspect={places[0].aspect} />
        <div class="mt-6 flex items-baseline justify-between gap-6">
          <div>
            <p class="caption text-brand-accent">{places[0].location}</p>
            <h3
              class="mt-3 font-serif text-3xl leading-tight sm:text-4xl"
            >
              {places[0].title}
            </h3>
          </div>
          <p class="caption shrink-0 text-brand-primary/45">No. 01</p>
        </div>
        <p class="mt-4 max-w-md text-base leading-relaxed text-brand-primary/75">
          {places[0].body}
        </p>
        <p class="caption mt-5 text-brand-primary/45">
          {places[0].season}
        </p>
      </article>

      <article class="col-span-12 sm:col-span-6 lg:col-span-5">
        <ShotList shot={places[1].shot} aspect={places[1].aspect} />
        <div class="mt-6 flex items-baseline justify-between gap-6">
          <div>
            <p class="caption text-brand-accent">{places[1].location}</p>
            <h3 class="mt-3 font-serif text-2xl leading-tight sm:text-3xl">
              {places[1].title}
            </h3>
          </div>
          <p class="caption shrink-0 text-brand-primary/45">No. 02</p>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-brand-primary/75 sm:text-base">
          {places[1].body}
        </p>
        <p class="caption mt-4 text-brand-primary/45">{places[1].season}</p>
      </article>

      <article class="col-span-12 sm:col-span-6 lg:col-span-5">
        <ShotList shot={places[2].shot} aspect={places[2].aspect} />
        <div class="mt-6 flex items-baseline justify-between gap-6">
          <div>
            <p class="caption text-brand-accent">{places[2].location}</p>
            <h3 class="mt-3 font-serif text-2xl leading-tight sm:text-3xl">
              {places[2].title}
            </h3>
          </div>
          <p class="caption shrink-0 text-brand-primary/45">No. 03</p>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-brand-primary/75 sm:text-base">
          {places[2].body}
        </p>
        <p class="caption mt-4 text-brand-primary/45">{places[2].season}</p>
      </article>

      <article class="col-span-12">
        <ShotList shot={places[3].shot} aspect={places[3].aspect} />
        <div
          class="mt-8 grid gap-6 lg:grid-cols-12 lg:items-baseline lg:gap-12"
        >
          <div class="lg:col-span-7">
            <p class="caption text-brand-accent">{places[3].location}</p>
            <h3
              class="mt-3 font-serif text-3xl leading-tight sm:text-4xl lg:text-5xl"
            >
              {places[3].title}
            </h3>
          </div>
          <div class="lg:col-span-5">
            <p class="text-base leading-relaxed text-brand-primary/75 sm:text-lg">
              {places[3].body}
            </p>
            <p class="caption mt-4 flex items-center gap-3 text-brand-primary/45">
              <span class="h-px w-6 bg-brand-primary/20"></span>
              No. 04 · {places[3].season}
            </p>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>
