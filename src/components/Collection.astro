---
import InlineVideo from "./InlineVideo.astro";
import ShotList from "./ShotList.astro";

const places = [
  {
    location: "New England Woodlands",
    title: "The Forest Trail",
    body:
      "Miles of winding trails through quiet conservation land, with your dog confidently leading the way. Best in the dappled light of late afternoon, when the woods quiet down.",
    shot:
      "Shallow depth of field, warm tones. A composed dog mid-stride on a woodland trail at golden hour, trees blurred behind. Soft natural light.",
    aspect: "4 / 5",
    image: "/collection-forest-trail.webp",
  },
  {
    location: "Rural New England",
    title: "The Open Field",
    body:
      "Wide open spaces where recall is proven. A dog who returns because the relationship is established, not because the leash demands it.",
    shot:
      "Warm sunset light on tall grass. A dog heeling beside an owner on a rural New England dirt path. Restrained, cinematic.",
    aspect: "4 / 5",
    video: "/woody-path.mp4",
  },
  {
    location: "The Country Stream",
    title: "Water & Working Dogs",
    body:
      "A cool break on a warm day. A dog who plays with purpose, then settles at the bank. The mark of a finished animal — visible only when nothing happens.",
    shot:
      "Shallow depth of field, warm tones. Dog behaving beautifully by a quiet New England stream. Cool water, warm tones, owner nearby.",
    aspect: "16 / 9",
    video: "/river-dogs.mp4",
  },
  {
    title: "Home, The Final Return",
    body:
      "The ultimate test of training is life at home. A dog at rest in a space they respect, part of the family without demanding the center of it.",
    shot:
      "Wide aspect, warm diffuse light. A cozy living room in soft focus behind. A dog resting calmly on a wool blanket, drawn back toward an owner just out of frame.",
    aspect: "16 / 9",
    video: "/boot-camp-pack.mp4",
  },
];
---

<section
  id="collection"
  class="relative bg-brand-bg"
  aria-labelledby="collection-heading"
>
  <div class="hairline mx-auto max-w-7xl"></div>
  <div class="mx-auto max-w-7xl px-6 py-28 sm:px-10 sm:py-36 lg:px-16 lg:py-44">
    <div
      class="grid gap-y-10 lg:grid-cols-12 lg:gap-x-12 xl:gap-x-20"
    >
      <div class="lg:col-span-4">
        <h2
          id="collection-heading"
          class="text-balance font-serif text-4xl leading-[1.05] sm:text-5xl lg:text-6xl"
        >
          A finer life,<br />
          <span class="italic text-brand-accent">already nearby.</span>
        </h2>
      </div>
      <div class="lg:col-span-7 lg:col-start-6">
        <p class="text-lg leading-relaxed text-brand-primary/75 sm:text-xl">
          Four standing settings where the work becomes visible
          &mdash; one woodland trail, one open field, one quiet stream,
          one peaceful return home.
        </p>
      </div>
    </div>

    <div
      class="mt-20 grid grid-cols-12 gap-x-6 gap-y-16 sm:gap-x-8 sm:gap-y-20"
    >
      <article class="col-span-12 lg:col-span-6 flex flex-col">
        {places[0].image ? (
          <img
            src={places[0].image}
            alt={places[0].shot}
            class="w-full border border-brand-primary/15 object-cover"
            style={`aspect-ratio: ${places[0].aspect};`}
            loading="lazy"
            decoding="async"
          />
        ) : places[0].video ? (
          <InlineVideo
            src={places[0].video}
            aspect={places[0].aspect}
            ariaLabel={places[0].shot}
            class="border-brand-primary/15"
          />
        ) : (
          <ShotList shot={places[0].shot} aspect={places[0].aspect} />
        )}
        <div class="mt-6 flex items-baseline justify-between gap-6">
          <div>
            <p class="caption text-brand-accent">{places[0].location}</p>
            <h3
              class="mt-3 font-serif text-3xl leading-tight sm:text-4xl"
            >
              {places[0].title}
            </h3>
          </div>
          <p class="caption shrink-0 text-brand-primary/45">No. 01</p>
        </div>
        <p class="mt-4 max-w-md text-base leading-relaxed text-brand-primary/75">
          {places[0].body}
        </p>
      </article>

      <article class="col-span-12 lg:col-span-6">
        {places[1].video ? (
          <InlineVideo
            src={places[1].video}
            aspect={places[1].aspect}
            ariaLabel={places[1].shot}
            class="border-brand-primary/15"
          />
        ) : (
          <ShotList shot={places[1].shot} aspect={places[1].aspect} />
        )}
        <div class="mt-6 flex items-baseline justify-between gap-6">
          <div>
            <p class="caption text-brand-accent">{places[1].location}</p>
            <h3 class="mt-3 font-serif text-2xl leading-tight sm:text-3xl">
              {places[1].title}
            </h3>
          </div>
          <p class="caption shrink-0 text-brand-primary/45">No. 02</p>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-brand-primary/75 sm:text-base">
          {places[1].body}
        </p>
      </article>

      <article class="col-span-12">
        <div class="w-full lg:w-[65%] lg:mx-auto">
          {places[2].video ? (
            <InlineVideo
              src={places[2].video}
              aspect={places[2].aspect}
              ariaLabel={places[2].shot}
              class="border-brand-primary/15"
            />
          ) : (
            <ShotList shot={places[2].shot} aspect={places[2].aspect} />
          )}
        </div>
        <div class="mt-6 flex items-baseline justify-between gap-6 lg:w-[65%] lg:mx-auto">
          <div>
            <p class="caption text-brand-accent">{places[2].location}</p>
            <h3 class="mt-3 font-serif text-2xl leading-tight sm:text-3xl">
              {places[2].title}
            </h3>
          </div>
          <p class="caption shrink-0 text-brand-primary/45">No. 03</p>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-brand-primary/75 sm:text-base lg:w-[65%] lg:mx-auto">
          {places[2].body}
        </p>
      </article>

      <article class="col-span-12">
        <div class="w-full lg:w-[65%] lg:mx-auto">
          {places[3].video ? (
            <InlineVideo
              src={places[3].video}
              aspect={places[3].aspect}
              ariaLabel={places[3].shot}
              class="border-brand-primary/15"
            />
          ) : (
            <ShotList shot={places[3].shot} aspect={places[3].aspect} />
          )}
        </div>
        <div
          class="mt-8 grid gap-6 lg:grid-cols-12 lg:items-baseline lg:gap-12 lg:w-[65%] lg:mx-auto"
        >
          <div class="lg:col-span-7">
            <h3
              class="font-serif text-3xl leading-tight sm:text-4xl lg:text-5xl"
            >
              {places[3].title}
            </h3>
          </div>
          <div class="lg:col-span-5">
            <p class="text-base leading-relaxed text-brand-primary/75 sm:text-lg">
              {places[3].body}
            </p>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>
