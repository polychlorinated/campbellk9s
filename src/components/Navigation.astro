---
const navLinks = [
  { href: "/services/", label: "Services" },
  { href: "/our-team/", label: "About" },
  { href: "/testimonials/", label: "Stories" },
  { href: "/faqs/", label: "FAQs" },
  { href: "/blog/", label: "Journal" },
  { href: "/contact/", label: "Contact" },
];
---

<header
  class="sticky top-0 z-50 bg-brand-bg/95 backdrop-blur supports-[backdrop-filter]:bg-brand-bg/85"
>
  <div class="hairline mx-auto max-w-7xl"></div>
  <nav
    class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6 sm:px-10 lg:px-16"
    aria-label="Primary"
  >
    <a
      href="/"
      class="group inline-flex items-center"
      aria-label="Campbell K9s — Home"
    >
      <img
        src="/ck9-blue-logo@2x.webp"
        alt="Campbell K9s"
        class="h-16 w-auto transition-opacity duration-300 group-hover:opacity-75"
      />
    </a>

    <ul class="hidden items-center gap-10 md:flex">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="caption group relative inline-block text-brand-primary/70 transition-colors hover:text-brand-primary"
            >
              {link.label}
              <span
                class="absolute -bottom-2 left-0 h-px w-0 bg-brand-accent transition-all duration-300 group-hover:w-full"
                aria-hidden="true"
              />
            </a>
          </li>
        ))
      }
    </ul>

    <div class="hidden items-center gap-5 md:flex">
      <a
        href="https://www.instagram.com/campbell_k9s"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Campbell K9s on Instagram"
        class="text-brand-primary/60 transition-colors hover:text-brand-accent"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2.2c3.2 0 3.6 0 4.85.07 1.17.05 1.8.25 2.23.42.56.22.96.48 1.38.9.42.42.68.82.9 1.38.17.42.37 1.06.42 2.23.06 1.25.07 1.65.07 4.85s0 3.6-.07 4.85c-.05 1.17-.25 1.8-.42 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.17-1.06.37-2.23.42-1.25.06-1.65.07-4.85.07s-3.6 0-4.85-.07c-1.17-.05-1.8-.25-2.23-.42a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.17-.42-.37-1.06-.42-2.23C2.2 15.6 2.2 15.2 2.2 12s0-3.6.07-4.85c.05-1.17.25-1.8.42-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.17 1.06-.37 2.23-.42C8.4 2.2 8.8 2.2 12 2.2zm0 3.06A4.94 4.94 0 1 1 7.06 12 4.94 4.94 0 0 1 12 7.06zm0 8.14A3.2 3.2 0 1 0 8.8 12a3.2 3.2 0 0 0 3.2 3.2zm5.14-8.36a1.15 1.15 0 1 1-1.15-1.15 1.15 1.15 0 0 1 1.15 1.15z"/>
        </svg>
      </a>
      <a
        href="https://www.tiktok.com/@campbell_k9s"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Campbell K9s on TikTok"
        class="text-brand-primary/60 transition-colors hover:text-brand-accent"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.88-2.88 2.89 2.89 0 0 1 2.88-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.1 8.1 0 0 0 4.74 1.52V6.76a4.85 4.85 0 0 1-.97-.07z"/>
        </svg>
      </a>

      <a
        href="#contact"
      class="group hidden items-center gap-2 bg-brand-primary px-5 py-3 text-[10px] font-medium uppercase tracking-[0.2em] text-brand-bg transition-all duration-300 hover:bg-brand-accent md:inline-flex"
    >
      Begin Conversation
      <span
        class="inline-block transition-transform duration-300 group-hover:translate-x-0.5"
        aria-hidden="true"
      >
        &rarr;
      </span>
    </a>
    </div>

    <button
      type="button"
      class="inline-flex items-center justify-center p-2 text-brand-primary md:hidden"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-mobile-menu-button
    >
      <svg
        class="h-5 w-5"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M4 7h16M4 12h16M4 17h16"></path>
      </svg>
    </button>
  </nav>

  <div
    id="mobile-menu"
    class="hidden border-t border-brand-primary/10 bg-brand-bg md:hidden"
    data-mobile-menu
  >
    <ul class="space-y-1 px-6 py-6 sm:px-10">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="caption block py-3 text-brand-primary/80 transition-colors hover:text-brand-accent"
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li class="pt-4">
        <a
          href="#contact"
          class="inline-flex items-center gap-2 bg-brand-primary px-5 py-3 text-[10px] font-medium uppercase tracking-[0.2em] text-brand-bg"
        >
          Begin Conversation &rarr;
        </a>
      </li>
    </ul>
  </div>

  <div class="hairline mx-auto max-w-7xl"></div>
</header>

<script>
  const btn = document.querySelector<HTMLButtonElement>(
    "[data-mobile-menu-button]"
  );
  const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");

  btn?.addEventListener("click", () => {
    const opened = menu?.classList.toggle("hidden") === false;
    btn.setAttribute("aria-expanded", String(opened));
  });
</script>
