---
// To enable the live calendar: open Google Calendar → Settings → [Your Calendar]
// → "Integrate calendar" → copy the embed src URL into CALENDAR_EMBED_URL below.
const CALENDAR_EMBED_URL = "";
---

<section
  id="community"
  class="relative bg-brand-bg"
  aria-labelledby="community-heading"
>
  <div class="hairline mx-auto max-w-7xl"></div>
  <div class="mx-auto max-w-7xl px-6 py-28 sm:px-10 sm:py-36 lg:px-16 lg:py-44">

    <!-- Section header -->
    <div class="grid gap-y-10 lg:grid-cols-12 lg:gap-x-12">
      <div class="lg:col-span-4">
        <p class="caption text-brand-accent">Community</p>
        <div class="mt-6 hairline max-w-[3rem]"></div>
      </div>
      <div class="lg:col-span-8">
        <h2
          id="community-heading"
          class="max-w-3xl text-balance font-serif text-4xl leading-[1.05] sm:text-5xl lg:text-6xl"
        >
          Beyond the session,{" "}
          <em class="not-italic font-serif italic text-brand-accent">
            a wider pack.
          </em>
        </h2>
        <p class="mt-8 max-w-2xl text-lg leading-relaxed text-brand-primary/75 sm:text-xl">
          Training doesn’t end at the driveway. We host pack walks, clinics,
          and community gatherings for clients and anyone who wants to do better
          by their dog. No pressure, no sales pitch — just good dogs and good
          people.
        </p>
      </div>
    </div>

    <!-- Two-column layout: calendar + swag -->
    <div class="mt-20 grid gap-y-16 lg:grid-cols-12 lg:gap-x-16">

      <!-- Events calendar -->
      <div class="lg:col-span-7">
        <p class="caption text-brand-primary/55">Upcoming Events</p>
        <div class="mt-6 hairline max-w-[3rem]"></div>
        {CALENDAR_EMBED_URL ? (
          <>
            <div
              class="mt-8 overflow-hidden border border-brand-line"
              style="aspect-ratio: 4/3;"
            >
              <iframe
                src={CALENDAR_EMBED_URL}
                title="Campbell K9s Community Calendar"
                width="100%"
                height="100%"
                frameborder="0"
                scrolling="no"
                loading="lazy"
                class="block h-full w-full"
                style="border: 0;"
              ></iframe>
            </div>
            <p class="mt-4 font-mono text-xs tracking-widest text-brand-primary/40 uppercase">
              All times Eastern &middot; Greater Boston &amp; Providence, RI
            </p>
          </>
        ) : (
          <div class="mt-8 border border-brand-line px-10 py-16 flex flex-col justify-center" style="aspect-ratio: 4/3;">
            <p class="font-serif text-3xl leading-tight sm:text-4xl">
              Events calendar<br />
              <span class="italic text-brand-accent">coming soon.</span>
            </p>
            <p class="mt-6 max-w-xs text-base leading-relaxed text-brand-primary/70">
              Pack walks, clinics, and community gatherings are announced first on Instagram and TikTok as they’re confirmed.
            </p>
            <div class="mt-10 flex flex-wrap items-center gap-6">
              <a
                href="https://www.instagram.com/campbell_k9s"
                target="_blank"
                rel="noopener noreferrer"
                class="group inline-flex items-center gap-3 text-sm font-medium uppercase tracking-[0.18em] text-brand-primary/70 transition-colors hover:text-brand-primary"
              >
                <span class="h-px w-8 bg-current transition-all group-hover:w-12"></span>
                Instagram
              </a>
              <a
                href="https://www.tiktok.com/@campbell_k9s"
                target="_blank"
                rel="noopener noreferrer"
                class="group inline-flex items-center gap-3 text-sm font-medium uppercase tracking-[0.18em] text-brand-primary/70 transition-colors hover:text-brand-primary"
              >
                <span class="h-px w-8 bg-current transition-all group-hover:w-12"></span>
                TikTok
              </a>
            </div>
          </div>
        )}
      </div>

      <!-- Swag store -->
      <div class="flex flex-col justify-center lg:col-span-5">
        <p class="caption text-brand-primary/55">The Gear</p>
        <div class="mt-6 hairline max-w-[3rem]"></div>
        <h3 class="mt-8 font-serif text-3xl leading-tight sm:text-4xl">
          Campbell K9s<br />
          <span class="italic text-brand-accent">Field Collection</span>
        </h3>
        <p class="mt-6 text-base leading-relaxed text-brand-primary/70 sm:text-lg">
          Apparel, gear, and accessories for people who take their dogs
          seriously. Built for the trail, the water, and the long walk
          home.
        </p>

        <div class="mt-10 space-y-4">
          {[
            "Trainer-approved field apparel",
            "Branded collars &amp; leads",
            "Limited drops for clients",
          ].map((item) => (
            <div class="flex items-start gap-3">
              <span
                class="mt-1.5 block h-1.5 w-1.5 shrink-0 rounded-full bg-brand-accent"
                aria-hidden="true"
              ></span>
              <p class="text-base text-brand-primary/70" set:html={item} />
            </div>
          ))}
        </div>

        <div class="mt-12">
          <a
            href="https://campbell-k9s.printify.me/"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-3 bg-brand-primary px-8 py-4 text-sm font-medium uppercase tracking-[0.18em] text-brand-bg transition-all duration-300 hover:bg-brand-accent"
          >
            <span>Visit the Store</span>
            <span
              class="inline-block transition-transform duration-300 group-hover:translate-x-1"
              aria-hidden="true"
            >
              &rarr;
            </span>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
