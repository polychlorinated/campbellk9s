---
// Hero — full-bleed cinematic statement with background video.

interface Props {
  videoSrc?: string;
  headingId?: string;
  videoLabel?: string;
}

const {
  videoSrc = "/ck9-hero-video.mp4",
  headingId = "hero-heading",
  videoLabel,
} = Astro.props;
---

<section
  class="relative isolate min-h-[92vh] w-full overflow-hidden bg-brand-primary text-brand-bg"
  aria-labelledby={headingId}
>
  <!-- Background Video Element -->
  <div class="absolute inset-0 z-0">
    <video
      class="h-full w-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="/ck9-icon-red-blue.png"
    >
      <source src={videoSrc} type="video/mp4" />
    </video>
    <!-- Overlay to ensure text remains readable against the video -->
    <div
      class="pointer-events-none absolute inset-0 bg-linear-to-t from-black/75 via-black/40 to-transparent"
    ></div>
  </div>

  <span
    class="pointer-events-none absolute left-6 top-6 z-10 h-4 w-4 border-l border-t border-brand-bg/30 sm:left-10 sm:top-10"
    aria-hidden="true"></span>
  <span
    class="pointer-events-none absolute right-6 top-6 z-10 h-4 w-4 border-r border-t border-brand-bg/30 sm:right-10 sm:top-10"
    aria-hidden="true"></span>
  <span
    class="pointer-events-none absolute bottom-6 left-6 z-10 h-4 w-4 border-b border-l border-brand-bg/30 sm:bottom-10 sm:left-10"
    aria-hidden="true"></span>
  <span
    class="pointer-events-none absolute bottom-6 right-6 z-10 h-4 w-4 border-b border-r border-brand-bg/30 sm:bottom-10 sm:right-10"
    aria-hidden="true"></span>

  {
    videoLabel && (
      <p class="caption absolute left-1/2 top-6 z-30 -translate-x-1/2 rounded-full border border-brand-bg/20 bg-brand-primary/80 px-4 py-2 text-brand-accent backdrop-blur-sm sm:top-10">
        {videoLabel}
      </p>
    )
  }

  <div
    class="relative z-10 mx-auto flex min-h-[92vh] max-w-7xl flex-col items-end justify-end px-6 pb-16 pt-32 text-right sm:px-10 sm:pb-24 lg:px-16 lg:pb-32"
  >
    <h1
      id={headingId}
      class="mt-7 max-w-5xl text-balance font-serif text-[clamp(2.75rem,7vw,7.5rem)] font-bold leading-[0.96] text-brand-bg"
    >
      Where dogs become
      <span class="italic text-brand-accent">themselves.</span>
    </h1>

    <p
      class="mt-7 max-w-xl text-base leading-relaxed text-brand-bg/75 sm:text-lg"
    >
      Quietly serious training — with room for mud, mischief, and real progress. For dogs who need more than a transaction, and families who want a life with them.
    </p>

    <div
      class="mt-10 flex flex-col items-end gap-x-10 gap-y-5 sm:flex-row sm:items-center sm:justify-end"
    >
      <a
        href="#contact"
        class="group relative inline-flex items-center gap-3 bg-brand-accent px-8 py-4 text-sm font-medium uppercase tracking-[0.18em] text-brand-primary transition-all duration-300 hover:bg-brand-bg"
      >
        Begin a Conversation
        <span
          class="inline-block transition-transform duration-300 group-hover:translate-x-1"
          aria-hidden="true"
        >
          &rarr;
        </span>
      </a>
      <a
        href="#philosophy"
        class="group inline-flex items-center gap-3 text-sm font-medium uppercase tracking-[0.18em] text-brand-bg/80 transition-colors hover:text-brand-bg"
      >
        <span class="h-px w-8 bg-current transition-all group-hover:w-12"
        ></span>
        Read the Philosophy
      </a>
    </div>
  </div>

  <!-- Live pulse strip -->
  <div
    class="absolute inset-x-0 bottom-0 z-20 border-t border-brand-bg/10 bg-brand-primary/40 backdrop-blur-sm"
  >
    <div
      class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 sm:px-10 lg:px-16"
    >
      <p class="caption text-brand-bg/70">
        <span class="mr-2 inline-block h-2 w-2 rounded-full bg-brand-accent animate-pulse" aria-hidden="true"></span>
        Follow the work in real time
      </p>
      <div class="flex items-center gap-3">
        <a
          href="https://www.instagram.com/campbell_k9s"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Campbell K9s on Instagram"
          class="text-brand-bg/70 transition-colors hover:text-brand-accent"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.2c3.2 0 3.6 0 4.85.07 1.17.05 1.8.25 2.23.42.56.22.96.48 1.38.9.42.42.68.82.9 1.38.17.42.37 1.06.42 2.23.06 1.25.07 1.65.07 4.85s0 3.6-.07 4.85c-.05 1.17-.25 1.8-.42 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.17-1.06.37-2.23.42-1.25.06-1.65.07-4.85.07s-3.6 0-4.85-.07c-1.17-.05-1.8-.25-2.23-.42a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.17-.42-.37-1.06-.42-2.23C2.2 15.6 2.2 15.2 2.2 12s0-3.6.07-4.85c.05-1.17.25-1.8.42-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.17 1.06-.37 2.23-.42C8.4 2.2 8.8 2.2 12 2.2zm0 3.06A4.94 4.94 0 1 1 7.06 12 4.94 4.94 0 0 1 12 7.06zm0 8.14A3.2 3.2 0 1 0 8.8 12a3.2 3.2 0 0 0 3.2 3.2zm5.14-8.36a1.15 1.15 0 1 1-1.15-1.15 1.15 1.15 0 0 1 1.15 1.15z"/>
          </svg>
        </a>
        <a
          href="https://www.tiktok.com/@campbell_k9s"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Campbell K9s on TikTok"
          class="text-brand-bg/70 transition-colors hover:text-brand-accent"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.88-2.88 2.89 2.89 0 0 1 2.88-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.1 8.1 0 0 0 4.74 1.52V6.76a4.85 4.85 0 0 1-.97-.07z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
