---
// From the Field — curated social proof grid.
// Replace the placeholder post URLs below with real Instagram/TikTok links.
// Instagram: https://www.instagram.com/p/{POST_ID}/
// TikTok:    https://www.tiktok.com/@campbell_k9s/video/{VIDEO_ID}

type SocialPost = {
  platform: "instagram" | "tiktok";
  url: string;
  caption: string;
};

const posts: SocialPost[] = [
  {
    platform: "instagram",
    url: "https://www.instagram.com/p/EXAMPLE1/",
    caption: "Morning pack walk. Five dogs, one tempo.",
  },
  {
    platform: "tiktok",
    url: "https://www.tiktok.com/@campbell_k9s/video/EXAMPLE2",
    caption: "The recall that took three weeks, not three years.",
  },
  {
    platform: "instagram",
    url: "https://www.instagram.com/p/EXAMPLE3/",
    caption: "Bootcamp graduation. Quietest car ride home ever.",
  },
  {
    platform: "tiktok",
    url: "https://www.tiktok.com/@campbell_k9s/video/EXAMPLE4",
    caption: "When the dog who pulled everywhere finally checks in.",
  },
];

const platformLabel = {
  instagram: "Instagram",
  tiktok: "TikTok",
};

function getInstagramPostId(url: string): string {
  const match = url.match(/\/p\/([^/]+)/);
  return match ? match[1] : "";
}

function getTikTokVideoId(url: string): string {
  const match = url.match(/video\/(\d+)/);
  return match ? match[1] : "";
}
---

<section
  id="from-the-field"
  class="relative bg-brand-bg"
  aria-labelledby="from-the-field-heading"
>
  <div class="hairline mx-auto max-w-7xl"></div>
  <div class="mx-auto max-w-7xl px-6 py-28 sm:px-10 sm:py-36 lg:px-16 lg:py-44">
    <div class="grid gap-y-10 lg:grid-cols-12 lg:gap-x-12">
      <div class="lg:col-span-5">
        <p class="caption text-brand-accent">From the Field</p>
        <h2
          id="from-the-field-heading"
          class="mt-6 text-balance font-serif text-4xl leading-[1.05] sm:text-5xl lg:text-6xl"
        >
          Real dogs, <em class="not-italic font-serif italic text-brand-accent"
            >real progress.</em
          >
        </h2>
      </div>
      <div class="lg:col-span-6 lg:col-start-7 lg:pt-6">
        <p class="text-lg leading-relaxed text-brand-primary/75 sm:text-xl">
          Training doesn’t happen in a brochure. It happens on the trail, in the
          living room, and in the small moments between commands. Here’s what
          that actually looks like.
        </p>
      </div>
    </div>

    <div
      class="mt-20 grid gap-8 sm:grid-cols-2 lg:grid-cols-4"
    >
      {
        posts.map((post) => (
          <article class="flex flex-col">
            <div class="overflow-hidden border border-brand-primary/10 bg-brand-primary/[0.02]">
              {post.platform === "instagram" ? (
                <blockquote
                  class="instagram-media"
                  data-instgrm-permalink={post.url}
                  data-instgrm-version="14"
                  data-instgrm-captioned={false}
                  style="background:#FFF; border:0; margin:1px; max-width:540px; min-width:326px; padding:0; width:99.375%;"
                >
                  <a href={post.url} target="_blank" rel="noopener noreferrer">
                    View this post on Instagram
                  </a>
                </blockquote>
              ) : (
                <blockquote
                  class="tiktok-embed"
                  cite={post.url}
                  data-video-id={getTikTokVideoId(post.url)}
                  style="max-width: 605px; min-width: 325px;"
                >
                  <section>
                    <a href={post.url} target="_blank" rel="noopener noreferrer">
                      View on TikTok
                    </a>
                  </section>
                </blockquote>
              )}
            </div>
            <div class="mt-5 flex items-center justify-between gap-4">
              <p class="caption text-brand-accent">{platformLabel[post.platform]}</p>
            </div>
            <p class="mt-2 text-base leading-relaxed text-brand-primary/75">
              {post.caption}
            </p>
          </article>
        ))
      }
    </div>

    <div class="mt-16 flex items-center justify-center gap-6">
      <a
        href="https://www.instagram.com/campbell_k9s"
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-3 text-sm font-medium uppercase tracking-[0.18em] text-brand-primary/70 transition-colors hover:text-brand-accent"
      >
        <span class="h-px w-8 bg-current transition-all group-hover:w-12"></span>
        Follow on Instagram
      </a>
      <a
        href="https://www.tiktok.com/@campbell_k9s"
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-3 text-sm font-medium uppercase tracking-[0.18em] text-brand-primary/70 transition-colors hover:text-brand-accent"
      >
        <span class="h-px w-8 bg-current transition-all group-hover:w-12"></span>
        Follow on TikTok
      </a>
    </div>
  </div>
</section>

<script async src="//www.instagram.com/embed.js"></script>
<script async src="https://www.tiktok.com/embed.js"></script>
