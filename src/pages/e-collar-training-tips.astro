---
import Layout from "../layouts/Layout.astro";

const principles = [
  {
    title: "It is a communication tool, not a punishment device.",
    description:
      "A modern e-collar delivers a low-level sensation — often a vibration or tone — to get a dog's attention at a distance. Used well, it becomes a quiet tap on the shoulder.",
  },
  {
    title: "Conditioning comes first.",
    description:
      "Before any off-leash work, the dog must understand what the sensation means and how to turn it off. We pair the lowest reliable level with known commands until the dog is fluent.",
  },
  {
    title: "Levels should be felt, not feared.",
    description:
      "The right level is the lowest level the dog notices. It should not cause yelping, cowering, or stress. If the dog looks worried, the level is too high or the foundation is missing.",
  },
  {
    title: "It is not a shortcut.",
    description:
      "An e-collar does not replace relationship, structure, or basic obedience. It extends communication once those things are solid. Skipping steps creates more problems than it solves.",
  },
];
---

<Layout
  title="E-Collar Training Tips & Best Practices — Campbell K9s"
  description="Ethical e-collar training tips from Campbell K9s. Learn how modern remote collars work, when they are appropriate, and why conditioning must come first."
>
  <!-- Page header -->
  <section class="relative bg-brand-primary text-brand-bg">
    <span
      class="pointer-events-none absolute left-6 top-6 h-4 w-4 border-l border-t border-brand-bg/20 sm:left-10 sm:top-10"
      aria-hidden="true"
    ></span>
    <span
      class="pointer-events-none absolute right-6 top-6 h-4 w-4 border-r border-t border-brand-bg/20 sm:right-10 sm:top-10"
      aria-hidden="true"
    ></span>

    <div
      class="mx-auto max-w-7xl px-6 pb-24 pt-20 sm:px-10 sm:pb-28 sm:pt-24 lg:px-16 lg:pb-32 lg:pt-28"
    >
      <p class="caption text-brand-accent">Tools</p>
      <h1
        class="mt-7 max-w-4xl text-balance font-serif text-[clamp(2.5rem,6vw,6rem)] font-bold leading-[0.96] text-brand-bg"
      >
        E-collar training:
        <span class="italic text-brand-accent">clarity at a distance.</span>
      </h1>
      <p class="mt-7 max-w-xl text-base leading-relaxed text-brand-bg/70 sm:text-lg">
        Remote collars are controversial for good reason. Used poorly, they
        damage trust. Used well — with conditioning, low levels, and clear
        intent — they can be one of the most humane ways to communicate off-leash.
      </p>
    </div>
  </section>

  <!-- Principles -->
  <section class="relative bg-brand-bg" aria-labelledby="principles-heading">
    <div class="mx-auto max-w-7xl px-6 py-20 sm:px-10 sm:py-28 lg:px-16 lg:py-36">
      <div class="grid gap-y-10 lg:grid-cols-12 lg:gap-x-16">
        <div class="lg:col-span-4">
          <p class="caption text-brand-accent">Best Practices</p>
          <h2
            id="principles-heading"
            class="mt-6 text-balance font-serif text-4xl leading-[1.05] sm:text-5xl"
          >
            Four rules for
            <span class="italic text-brand-accent">ethical use.</span>
          </h2>
        </div>
        <div class="lg:col-span-8">
          <div class="space-y-12">
            {
              principles.map((item, i) => (
                <div class="grid gap-6 border-b border-brand-line pb-12 sm:grid-cols-12">
                  <div class="sm:col-span-3">
                    <p class="caption text-brand-primary/45">0{i + 1}</p>
                  </div>
                  <div class="sm:col-span-9">
                    <h3 class="font-serif text-2xl leading-tight text-brand-primary">
                      {item.title}
                    </h3>
                    <p class="mt-4 text-base leading-relaxed text-brand-primary/75 sm:text-lg">
                      {item.description}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- When to seek help -->
  <section class="relative bg-brand-primary text-brand-bg">
    <div class="hairline mx-auto max-w-7xl bg-brand-bg/10"></div>
    <div class="mx-auto max-w-7xl px-6 py-20 sm:px-10 sm:py-28 lg:px-16 lg:py-36">
      <div class="grid gap-y-10 lg:grid-cols-12 lg:gap-x-16">
        <div class="lg:col-span-4">
          <p class="caption text-brand-accent">Guidance</p>
          <div class="mt-6 hairline max-w-[3rem] bg-brand-bg/20"></div>
        </div>
        <div class="lg:col-span-8">
          <div class="max-w-2xl space-y-6 text-lg leading-relaxed text-brand-bg/80 sm:text-xl">
            <p>
              If you are new to e-collars, work with a professional before you
              put one on your dog. The timing, level selection, and conditioning
              process matter more than the brand of collar you choose.
            </p>
            <p>
              We do not sell collars or require specific brands. We teach you
              how to use the tool fairly, how to read your dog's response, and
              how to maintain trust while gaining off-leash reliability.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative bg-brand-bg">
    <div class="hairline mx-auto max-w-7xl"></div>
    <div class="mx-auto max-w-7xl px-6 py-20 sm:px-10 sm:py-28 lg:px-16 lg:py-36">
      <div class="grid gap-y-10 lg:grid-cols-12 lg:gap-x-16">
        <div class="lg:col-span-7">
          <p class="caption text-brand-accent">Questions?</p>
          <h2 class="mt-6 max-w-xl text-balance font-serif text-4xl leading-[1.05] sm:text-5xl">
            Get honest guidance
            <span class="italic text-brand-accent">before you buy.</span>
          </h2>
        </div>
        <div class="flex flex-col justify-center lg:col-span-5">
          <p class="text-base leading-relaxed text-brand-primary/70 sm:text-lg">
            Not sure if an e-collar is right for your dog? Our lead trainer will
            walk you through the decision without a sales pitch.
          </p>
          <div class="mt-10">
            <a
              href="/contact/"
              class="group inline-flex items-center gap-3 bg-brand-accent px-8 py-4 text-sm font-medium uppercase tracking-[0.18em] text-brand-primary transition-all duration-300 hover:bg-brand-primary hover:text-brand-bg"
            >
              Ask About E-Collar Training
              <span
                class="inline-block transition-transform duration-300 group-hover:translate-x-1"
                aria-hidden="true"
              >
                &rarr;
              </span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
