---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Campbell K9s Privacy Policy — How We Protect Your Data"
  description="How Campbell K9s collects, uses, and protects your personal information."
>
  <div class="mx-auto max-w-3xl px-6 py-28 sm:px-10 sm:py-36 lg:px-8 lg:py-44">
    <p class="caption text-brand-accent">Legal</p>
    <h1 class="mt-6 font-serif text-4xl leading-tight sm:text-5xl">
      Privacy Policy
    </h1>
    <p class="caption mt-4 text-brand-primary/50">Last updated: June 2026</p>

    <div class="mt-12 hairline max-w-[3rem]"></div>

    <div class="mt-12 space-y-10 text-base leading-relaxed text-brand-primary/80 sm:text-lg">
      <div>
        <h2 class="font-serif text-2xl text-brand-primary">Information We Collect</h2>
        <p class="mt-4">
          When you submit an inquiry through our contact form, we collect your
          name, phone number, and information about your dog. We use this
          information solely to respond to your inquiry and to assess whether our
          program is a good fit.
        </p>
      </div>

      <div>
        <h2 class="font-serif text-2xl text-brand-primary">How We Use Your Information</h2>
        <p class="mt-4">
          Your information is used to contact you about your inquiry. We do not
          sell, trade, or share your personal information with third parties for
          marketing purposes.
        </p>
      </div>

      <div>
        <h2 class="font-serif text-2xl text-brand-primary">Data Retention</h2>
        <p class="mt-4">
          We retain inquiry information only as long as necessary to respond to
          your request. You may contact us at any time to request deletion of
          your information.
        </p>
      </div>

      <div>
        <h2 class="font-serif text-2xl text-brand-primary">Contact</h2>
        <p class="mt-4">
          Questions about this policy can be directed to{" "}
          <a
            href="mailto:k9campbellmatt@gmail.com"
            class="border-b border-brand-primary/30 pb-0.5 transition-colors hover:border-brand-accent hover:text-brand-accent"
          >
            k9campbellmatt@gmail.com
          </a>.
        </p>
      </div>
    </div>
  </div>
</Layout>
