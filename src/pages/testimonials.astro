---
import Layout from "../layouts/Layout.astro";

const testimonials = [
  {
    quote:
      "We did board training for our dog Daisy who was anxious around other dogs and in public settings as a result of abuse prior to us adopting her. With just one week of training, the difference was clear. She is confident, friendly, and takes off-leash hikes happily with the pack each week.",
    name: "Becca Rutenberg",
    location: "Google Review",
    dog: "Daisy",
  },
  {
    quote:
      "Matt and Mary were so helpful in getting our 1-year old Labradoodle Tate into Training Bootcamp. Matt gave us helpful insight, guidance and training tools to make our lives together with Tate run smoother and happier for all — Thank you!!!",
    name: "Mary Ellen Paravalos",
    location: "Google Review",
    dog: "Tate, Labradoodle",
  },
  {
    quote:
      "Our main focus was off-leash training, recall, jumping on guests and counter surfing. All behaviors were corrected. Benson has been part of the adventure hikes for 2 years now and absolutely loves it. It gives me peace of mind knowing he is in good hands and they treat him like their own family dog!",
    name: "Ashley Shaw",
    location: "Google Review",
    dog: "Benson, Sheepadoodle",
  },
];
---

<Layout
  title="Campbell K9s Client Stories & Board & Train Results"
  description="Real results from families across Greater Boston and Providence. Watch Abby's Board & Train story and read what our clients say about the Campbell K9s program."
>

  <!-- Page header -->
  <section class="relative bg-brand-primary text-brand-bg">
    <span class="pointer-events-none absolute left-6 top-6 h-4 w-4 border-l border-t border-brand-bg/20 sm:left-10 sm:top-10" aria-hidden="true"></span>
    <span class="pointer-events-none absolute right-6 top-6 h-4 w-4 border-r border-t border-brand-bg/20 sm:right-10 sm:top-10" aria-hidden="true"></span>

    <div class="mx-auto max-w-7xl px-6 pb-24 pt-20 sm:px-10 sm:pb-28 sm:pt-24 lg:px-16 lg:pb-32 lg:pt-28">
      <p class="caption text-brand-accent">Client Stories</p>
      <h1 class="mt-7 max-w-3xl text-balance font-serif text-[clamp(2.5rem,6vw,6rem)] font-bold leading-[0.96] text-brand-bg">
        The work,
        <span class="italic text-brand-accent">in their words.</span>
      </h1>
      <p class="mt-7 max-w-xl text-base leading-relaxed text-brand-bg/70 sm:text-lg">
        A small number of families each season. Each one a different dog, a different starting point, the same standard.
      </p>
    </div>
  </section>

  <!-- Featured story: Abby -->
  <section class="relative bg-brand-bg" aria-labelledby="abby-heading">
    <div class="mx-auto max-w-7xl px-6 py-20 sm:px-10 sm:py-28 lg:px-16 lg:py-36">

      <div class="grid items-start gap-y-14 lg:grid-cols-12 lg:gap-x-16">

        <!-- Video -->
        <div class="lg:col-span-5">
          <p class="caption text-brand-accent">Featured Story</p>
          <div class="mt-6 hairline max-w-[3rem]"></div>
          <div
            class="mt-8 overflow-hidden border border-brand-line"
            style="aspect-ratio: 9/16; max-width: 360px;"
          >
            <iframe
              src="https://www.youtube.com/embed/fkRztC43Ipk"
              title="Abby's Board & Train Bootcamp Story — Campbell K9s"
              width="100%"
              height="100%"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
              class="block h-full w-full"
            ></iframe>
          </div>
        </div>

        <!-- Story text -->
        <div class="lg:col-span-7 lg:pt-16">
          <h2
            id="abby-heading"
            class="max-w-xl text-balance font-serif text-4xl leading-[1.05] sm:text-5xl lg:text-6xl"
          >
            Abby's
            <em class="not-italic font-serif italic text-brand-accent">
              bootcamp story.
            </em>
          </h2>

          <div class="mt-10 max-w-lg space-y-6 text-base leading-relaxed text-brand-primary/75 sm:text-lg">
            <p>
              Abby came to us with the kind of energy that makes walks feel like work — reactive, unfocused, and pulling against everything. Her family loved her completely. They just couldn't get ahead of her.
            </p>
            <p>
              Over four weeks in our Board & Train Bootcamp, Abby learned what it meant to move through the world with a calmer mind. Off-leash reliability. Settled behavior at home. A dog who returns because she wants to.
            </p>
            <p>
              The footage is unscripted. That's what the work looks like when it's finished.
            </p>
          </div>

          <dl class="mt-12 grid grid-cols-2 gap-x-10 gap-y-8 sm:grid-cols-3">
            <div>
              <dt class="caption text-brand-primary/50">Program</dt>
              <dd class="mt-2 font-serif text-lg text-brand-primary">Board & Train</dd>
            </div>
            <div>
              <dt class="caption text-brand-primary/50">Duration</dt>
              <dd class="mt-2 font-serif text-lg text-brand-primary">Four weeks</dd>
            </div>
            <div>
              <dt class="caption text-brand-primary/50">Location</dt>
              <dd class="mt-2 font-serif text-lg text-brand-primary">Greater Boston</dd>
            </div>
          </dl>
        </div>

      </div>
    </div>
  </section>

  <!-- Text testimonials -->
  <section class="relative bg-brand-primary text-brand-bg" aria-labelledby="testimonials-grid-heading">
    <div class="hairline mx-auto max-w-7xl bg-brand-bg/10"></div>
    <div class="mx-auto max-w-7xl px-6 py-20 sm:px-10 sm:py-28 lg:px-16 lg:py-36">

      <div class="grid gap-y-10 lg:grid-cols-12 lg:gap-x-12">
        <div class="lg:col-span-4">
          <p class="caption text-brand-accent">More from our clients</p>
          <div class="mt-6 hairline max-w-[3rem] bg-brand-bg/20"></div>
        </div>
        <div class="lg:col-span-8">
          <h2
            id="testimonials-grid-heading"
            class="max-w-3xl text-balance font-serif text-4xl leading-[1.05] text-brand-bg sm:text-5xl"
          >
            The families
            <em class="not-italic font-serif italic text-brand-accent">
              who trusted the work.
            </em>
          </h2>
        </div>
      </div>

      <div class="mt-20 grid gap-x-12 gap-y-16 lg:grid-cols-3">
        {
          testimonials.map((t) => (
            <figure class="flex flex-col">
              <span
                class="font-serif text-5xl leading-none text-brand-accent"
                aria-hidden="true"
              >
                &ldquo;
              </span>
              <blockquote class="mt-4 flex-1 font-serif text-lg italic leading-relaxed text-brand-bg/85 sm:text-xl">
                {t.quote}
              </blockquote>
              <figcaption class="mt-8 border-t border-brand-bg/15 pt-6">
                <p class="font-serif text-base text-brand-bg">{t.name}</p>
                <p class="caption mt-1 text-brand-bg/50">
                  {t.location} &middot; {t.dog}
                </p>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative bg-brand-bg">
    <div class="hairline mx-auto max-w-7xl"></div>
    <div class="mx-auto max-w-7xl px-6 py-20 sm:px-10 sm:py-28 lg:px-16 lg:py-36">
      <div class="grid gap-y-10 lg:grid-cols-12 lg:gap-x-16">
        <div class="lg:col-span-7">
          <p class="caption text-brand-accent">Ready to begin?</p>
          <h2 class="mt-6 max-w-xl text-balance font-serif text-4xl leading-[1.05] sm:text-5xl">
            We accept a small number of dogs
            <span class="italic text-brand-accent">each season.</span>
          </h2>
        </div>
        <div class="flex flex-col justify-center lg:col-span-5">
          <p class="text-base leading-relaxed text-brand-primary/70 sm:text-lg">
            Tell us about your dog. Our lead trainer will write back within twenty-four hours.
          </p>
          <div class="mt-10">
            <a
              href="/#contact"
              class="group inline-flex items-center gap-3 bg-brand-accent px-8 py-4 text-sm font-medium uppercase tracking-[0.18em] text-brand-primary transition-all duration-300 hover:bg-brand-primary hover:text-brand-bg"
            >
              Begin a Conversation
              <span class="inline-block transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">
                &rarr;
              </span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
