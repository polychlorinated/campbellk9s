---
import Layout from "../../layouts/Layout.astro";
import {
  getPosts,
  featuredImage,
  featuredImageAlt,
  postCategories,
  formatDate,
  getPostsUrl,
} from "../../lib/wordpress";

const siteUrl = "https://campbellk9s.com";
const wordpressPostsUrl = getPostsUrl();

const posts = await getPosts();
---

<Layout
  title="Campbell K9 Journal — Dog Training Field Notes & Stories"
  description="Training insights, field notes, and stories from New England's most dedicated dog training practice."
>
  <section class="mx-auto max-w-7xl px-6 py-24 sm:px-10 sm:py-32 lg:px-16">
    <div class="mb-16">
      <div class="hairline mb-10"></div>
      <span class="caption text-brand-accent">Field Notes</span>
      <h1 class="mt-4 font-serif text-5xl sm:text-6xl lg:text-7xl">
        The Journal
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-brand-muted">
        Training insights, field reflections, and stories from the work.
      </p>
      <div class="hairline mt-10"></div>
    </div>

    {
      <div
        class:list={["grid gap-12 sm:grid-cols-2 lg:grid-cols-3", posts.length === 0 && "hidden"]}
        data-blog-grid
      >
          {posts.map((post) => {
            const img = featuredImage(post);
            const alt = featuredImageAlt(post);
            const cats = postCategories(post);
            return (
              <article class="group flex flex-col">
                <a
                  href={`${siteUrl}/blog/${post.slug}/`}
                  class="block overflow-hidden"
                  tabindex="-1"
                  aria-hidden="true"
                >
                  {img ? (
                    <div class="aspect-[4/3] overflow-hidden bg-brand-line">
                      <img
                        src={img}
                        alt={alt}
                        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                        loading="lazy"
                      />
                    </div>
                  ) : (
                    <div class="aspect-[4/3] flex items-center justify-center bg-brand-primary/5">
                      <span class="caption text-brand-muted">Campbell K9</span>
                    </div>
                  )}
                </a>
                <div class="mt-5 flex flex-1 flex-col">
                  <div class="flex items-center gap-4">
                    {cats.length > 0 && (
                      <span class="caption text-brand-accent">
                        {cats[0].name}
                      </span>
                    )}
                    <span class="caption text-brand-muted">
                      {formatDate(post.date)}
                    </span>
                  </div>
                  <h2 class="mt-3 font-serif text-2xl leading-snug">
                    <a
                      href={`${siteUrl}/blog/${post.slug}/`}
                      class="transition-colors hover:text-brand-accent"
                      set:html={post.title.rendered}
                    />
                  </h2>
                  <div
                    class="post-excerpt mt-3 text-sm leading-relaxed text-brand-muted"
                    set:html={post.excerpt.rendered}
                  />
                  <a
                    href={`${siteUrl}/blog/${post.slug}/`}
                    class="caption mt-5 inline-flex items-center gap-2 text-brand-accent transition-all hover:gap-3"
                  >
                    Read More <span aria-hidden="true">&rarr;</span>
                  </a>
                </div>
              </article>
            );
          })}
      </div>
    }

    <p
      class:list={["caption text-brand-muted", posts.length > 0 && "hidden"]}
      data-blog-status
      role="status"
    >
      Loading field notes&hellip;
    </p>
  </section>

  <script define:vars={{ wordpressPostsUrl, siteUrl }}>
    const grid = document.querySelector("[data-blog-grid]");
    const status = document.querySelector("[data-blog-status]");

    if (grid instanceof HTMLElement) {
      const decodeText = (html) => {
        const doc = new DOMParser().parseFromString(html, "text/html");
        return doc.body.textContent?.trim() || "";
      };

      const addText = (element, text) => {
        element.textContent = text;
        return element;
      };

      fetch(wordpressPostsUrl, {
        headers: { Accept: "application/json" },
        cache: "no-store",
        signal: AbortSignal.timeout(8000),
      })
        .then((response) => {
          if (!response.ok) throw new Error(`WordPress returned ${response.status}`);
          return response.json();
        })
        .then((posts) => {
          if (!Array.isArray(posts) || posts.length === 0) {
            throw new Error("No published posts returned");
          }

          grid.replaceChildren();

          for (const post of posts) {
            const href = `${siteUrl}/blog/${encodeURIComponent(post.slug)}/`;
            const media = post._embedded?.["wp:featuredmedia"]?.[0];
            const category = post._embedded?.["wp:term"]?.[0]?.[0]?.name;
            const article = document.createElement("article");
            article.className = "group flex flex-col";

            const imageLink = document.createElement("a");
            imageLink.href = href;
            imageLink.className = "block overflow-hidden";
            imageLink.tabIndex = -1;
            imageLink.setAttribute("aria-hidden", "true");

            const imageFrame = document.createElement("div");
            imageFrame.className = "aspect-[4/3] overflow-hidden bg-brand-line";
            if (media?.source_url) {
              const image = document.createElement("img");
              image.src = media.source_url;
              image.alt = media.alt_text || "";
              image.loading = "lazy";
              image.className =
                "h-full w-full object-cover transition-transform duration-500 group-hover:scale-105";
              imageFrame.append(image);
            } else {
              imageFrame.className += " flex items-center justify-center bg-brand-primary/5";
              imageFrame.append(
                addText(document.createElement("span"), "Campbell K9")
              );
              imageFrame.firstElementChild?.classList.add(
                "caption",
                "text-brand-muted"
              );
            }
            imageLink.append(imageFrame);

            const content = document.createElement("div");
            content.className = "mt-5 flex flex-1 flex-col";
            const meta = document.createElement("div");
            meta.className = "flex items-center gap-4";
            if (category) {
              const categoryLabel = addText(document.createElement("span"), category);
              categoryLabel.className = "caption text-brand-accent";
              meta.append(categoryLabel);
            }
            const date = addText(
              document.createElement("span"),
              new Date(post.date).toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })
            );
            date.className = "caption text-brand-muted";
            meta.append(date);

            const heading = document.createElement("h2");
            heading.className = "mt-3 font-serif text-2xl leading-snug";
            const titleLink = addText(
              document.createElement("a"),
              decodeText(post.title?.rendered || "Untitled")
            );
            titleLink.href = href;
            titleLink.className = "transition-colors hover:text-brand-accent";
            heading.append(titleLink);

            const excerpt = addText(
              document.createElement("p"),
              decodeText(post.excerpt?.rendered || "")
            );
            excerpt.className = "mt-3 text-sm leading-relaxed text-brand-muted";

            const readMore = addText(document.createElement("a"), "Read More →");
            readMore.href = href;
            readMore.className =
              "caption mt-5 inline-flex items-center gap-2 text-brand-accent transition-all hover:gap-3";

            content.append(meta, heading, excerpt, readMore);
            article.append(imageLink, content);
            grid.append(article);
          }

          grid.classList.remove("hidden");
          status?.classList.add("hidden");
        })
        .catch((error) => {
          console.error("[blog] Unable to load posts", error);
          if (status && grid.children.length === 0) {
            status.textContent = "The journal is temporarily unavailable. Please refresh shortly.";
          } else {
            status?.classList.add("hidden");
          }
        });
    }
  </script>
</Layout>
